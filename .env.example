# EcoTrack Environment Variables Template
# Copy this file to .env and fill in your actual values

# ================================
# MONGODB DATABASE CONFIGURATION
# ================================
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/your-database?retryWrites=true&w=majority&appName=EcoTrack

# ================================
# FIREBASE CONFIGURATION
# ================================
FIREBASE_API_KEY=your-firebase-api-key-here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# ================================
# SERVER CONFIGURATION
# ================================
NODE_ENV=production
PORT=5000
CORS_ORIGIN=https://your-frontend-domain.netlify.app

# ================================
# CLIENT CONFIGURATION
# ================================
VITE_API_URL=https://your-backend-domain.vercel.app/api
VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# ================================
# DEPLOYMENT CONFIGURATION
# ================================
# Netlify will automatically set these during deployment
# Vercel will use the vercel.json configuration

# ================================
# INSTRUCTIONS
# ================================
# 1. For MongoDB:
#    - Go to MongoDB Atlas (https://cloud.mongodb.com/)
#    - Create a new cluster or use existing one
#    - Get the connection string from Connect > Connect your application
#    - Replace the MONGODB_URI value above

# 2. For Firebase:
#    - Go to Firebase Console (https://console.firebase.google.com/)
#    - Select your project (or create new one)
#    - Go to Project Settings > General
#    - Copy the Firebase configuration values
#    - Replace all FIREBASE_* values above

# 3. For Deployment:
#    - Frontend: Deploy to Netlify using netlify.toml
#    - Backend: Deploy to Vercel using vercel.json
#    - Set environment variables in deployment platforms

# 4. Security Notes:
#    - Never commit .env file to version control
#    - Add .env to .gitignore
#    - Use different values for development and production
