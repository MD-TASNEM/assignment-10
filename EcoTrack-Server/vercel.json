{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/challenges/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/user-challenges/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/tips/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/events/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/stats/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/auth/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/health",
      "dest": "server.js"
    },
    {
      "src": "/",
      "dest": "server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}