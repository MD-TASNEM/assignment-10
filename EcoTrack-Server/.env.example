# Copy to .env — never commit real secrets

PORT=5000
NODE_ENV=development

# MongoDB Atlas (or local)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/ecotrack?retryWrites=true&w=majority

# JWT for protected API routes (use a long random string in production)
JWT_SECRET=

# Comma-separated allowed browser origins (SPA URLs)
CLIENT_URL=https://your-app.netlify.app,http://localhost:5173
