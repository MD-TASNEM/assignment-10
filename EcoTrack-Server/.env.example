# EcoTrack Server Environment Variables

PORT=5000
NODE_ENV=development

# MongoDB Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/docs/atlas/
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# JWT Secret for protected API routes
# Generate a random string for production
JWT_SECRET=your_super_secret_random_string_here

# Comma-separated allowed browser origins (SPA URLs)
# For local development
CLIENT_URL=http://localhost:5173,http://localhost:3000

# For production, use your deployed client URL
# CLIENT_URL=https://your-app.netlify.app
